generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── JOGO (título/plataforma) ──────────────────────────
// Nota: "Game" aqui = Counter-Strike, Valorant, etc.
// O que o usuário chama de "jogo" (MD3) é o model Jogo abaixo.

model Game {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  coverUrl  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  maps     Map[]
  corujoes Corujao[]
}

// ─── JOGADOR ──────────────────────────────────────────

model Player {
  id        String   @id @default(cuid())
  name      String
  nickname  String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  corujoes     CorujaoPlayer[]
  jogoSlots    JogoMembro[]
  jogoMapStats JogoMapStat[]
}

// ─── MAPA ─────────────────────────────────────────────

model Map {
  id          String  @id @default(cuid())
  name        String
  displayName String
  imageUrl    String?
  isActive    Boolean @default(true)

  gameId       String
  game         Game          @relation(fields: [gameId], references: [id])
  banPicks     BanPick[]
  jogoMapStats JogoMapStat[]

  @@unique([gameId, name])
}

// ─── CORUJÃO ──────────────────────────────────────────

model Corujao {
  id        String        @id @default(cuid())
  name      String
  date      DateTime
  status    CorujaoStatus @default(DRAFT)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  gameId String
  game   Game   @relation(fields: [gameId], references: [id])

  players CorujaoPlayer[]
  jogos   Jogo[]
}

model CorujaoPlayer {
  corujaoId String
  playerId  String
  corujao   Corujao @relation(fields: [corujaoId], references: [id], onDelete: Cascade)
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([corujaoId, playerId])
}

// ─── JOGO (série MD1/MD3/MD5) ─────────────────────────

model Jogo {
  id           String       @id @default(cuid())
  sequence     Int
  format       MatchFormat  @default(MD1)
  status       MatchStatus  @default(SCHEDULED)
  nameTeamA    String?
  nameTeamB    String?
  scoreTeamA   Int?
  scoreTeamB   Int?
  playedAt     DateTime?
  createdAt    DateTime     @default(now())
  creationMode CreationMode @default(MANUAL)
  draftStatus  DraftStatus?
  draftTurn    MatchSide?

  corujaoId String
  corujao   Corujao @relation(fields: [corujaoId], references: [id], onDelete: Cascade)

  membros  JogoMembro[]
  banPicks BanPick[]
  mapStats JogoMapStat[]

  @@unique([corujaoId, sequence])
}

model JogoMembro {
  id        String    @id @default(cuid())
  side      MatchSide
  isCaptain Boolean   @default(false)
  jogoId    String
  playerId  String
  jogo      Jogo   @relation(fields: [jogoId], references: [id], onDelete: Cascade)
  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([jogoId, playerId])
}

// ─── BAN/PICK ─────────────────────────────────────────

model BanPick {
  id     String        @id @default(cuid())
  action BanPickAction
  order  Int
  side   MatchSide?

  jogoId String
  mapId  String
  jogo   Jogo   @relation(fields: [jogoId], references: [id], onDelete: Cascade)
  map    Map    @relation(fields: [mapId], references: [id])

  @@unique([jogoId, order])
}

// ─── STATS POR MAPA ───────────────────────────────────

model JogoMapStat {
  id      String @id @default(cuid())
  kills   Int    @default(0)
  deaths  Int    @default(0)
  assists Int    @default(0)

  jogoId   String
  mapId    String
  playerId String
  jogo     Jogo   @relation(fields: [jogoId], references: [id], onDelete: Cascade)
  map      Map    @relation(fields: [mapId], references: [id])
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([jogoId, mapId, playerId])
}

// ─── ENUMS ────────────────────────────────────────────

enum CorujaoStatus {
  DRAFT
  IN_PROGRESS
  FINISHED
}

enum MatchFormat {
  MD1
  MD3
  MD5
}

enum MatchStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum MatchSide {
  TEAM_A
  TEAM_B
}

enum BanPickAction {
  BAN
  PICK
  DECIDER
}

enum CreationMode {
  MANUAL
  DRAFT
}

enum DraftStatus {
  DRAFTING
  COMPLETED
}
